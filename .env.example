# AIMF environment variables
#
# Copy to `.env` in the project root (or any parent of the working directory).
# AIMF loads `.env` automatically when reading configuration. Existing shell
# environment variables always win over `.env` values.
#
# Never commit a real `.env` file.

# --- Logging ---
AIMF_LOG_LEVEL=WARNING
AIMF_LOG_FORMAT=text

# --- Private GitHub HTTPS clones ---
# Reference this name from aimf.toml: [repository.authentication] token_env = "AIMF_GITHUB_TOKEN"
# AIMF_GITHUB_TOKEN=

# --- Optional AI-enhanced assessment (Amazon Bedrock) ---
# Prefer [aws] / [ai.bedrock] in aimf.toml. These are optional overrides:
# AWS_PROFILE=aimf
# AWS_REGION=us-east-1
# AIMF_BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# --- Optional PMD override (Java static analysis) ---
# AIMF_PMD_PATH=/opt/homebrew/bin/pmd
